{
  "name": "lucy-bodasesor-kommo",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "description": "Lucy API — producción Hostinger (bundle precompilado en deploy/)",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "build": "node -e \"require('fs').accessSync('deploy/index.mjs');console.log('[build] deploy/ precompilado OK')\"",
    "deploy:hostinger": "node scripts/deploy-hostinger.mjs",
    "deploy:hostinger:restart": "node scripts/deploy-hostinger.mjs --restart",
    "start": "node start.mjs",
    "postinstall": "echo \"Lucy: sin dependencias npm — bundle en deploy/\""
  },
  "engines": {
    "node": ">=22"
  }
}
