# ═══════════════════════════════════════════════════════════════
# KEY DE OPENAI — Bodasesor usa OPEN_AI en Hostinger
# ═══════════════════════════════════════════════════════════════

# En Hostinger → Variable de entorno:
#   Nombre:  OPEN_AI
#   Valor:   sk-proj-tu-key-completa

OPEN_AI=

# Alias alternativo (también funciona):
# OPENAI_API_KEY=

# Solo modelo para agente simple del simulador (NO es la key):
OPENAI_MODEL=gpt-4o-mini

AGENT_WEBHOOK_URL=http://localhost:3000/api/kommo/simulator

# Kommo producción (solo cuando conectes el CRM real)
KOMMO_SUBDOMAIN=
KOMMO_ACCESS_TOKEN=

# DATABASE_URL=postgresql://...
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
