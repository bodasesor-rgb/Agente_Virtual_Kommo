# ═══════════════════════════════════════════════════════════════
# SIMULADOR (Python) — lee este .env automáticamente
# ═══════════════════════════════════════════════════════════════

# Tu key secreta de OpenAI (empieza con sk-proj- o sk-)
# NO es el nombre del modelo. NO uses OPEN_AI (con guión bajo).
OPENAI_API_KEY=

# Solo para el agente simple del simulador (si Lucy no responde).
# Lucy siempre usa gpt-4o-mini — no lee esta variable.
OPENAI_MODEL=gpt-4o-mini

# URL de Lucy (debe terminar en /api/kommo/simulator)
AGENT_WEBHOOK_URL=http://localhost:3000/api/kommo/simulator

# ═══════════════════════════════════════════════════════════════
# LUCY (Node) — si corres local: pon OPENAI_API_KEY también en
# este mismo .env (Lucy ya carga dotenv) o expórtala en terminal:
#   export OPENAI_API_KEY=sk-proj-...
#   node api-server/dist/index.mjs
# ═══════════════════════════════════════════════════════════════

# En HOSTINGER → Variables de entorno del panel:
#   Nombre:  OPENAI_API_KEY
#   Valor:   sk-proj-...  (sin comillas, sin espacios)

# Kommo producción (solo cuando conectes el CRM real)
KOMMO_SUBDOMAIN=
KOMMO_ACCESS_TOKEN=

# Base de datos — OPCIONAL (sin esto usa data/lucy-pgdata local)
# DATABASE_URL=postgresql://...

# WhatsApp Meta API
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
