# Simulador → por defecto usa Lucy en Hostinger (ya tiene OPEN_AI)
AGENT_WEBHOOK_URL=https://midnightblue-mosquito-424375.hostingersite.com/api/kommo/simulator

# Solo si usas Lucy local en :3000 (necesitas export OPEN_AI ahí también):
# AGENT_WEBHOOK_URL=http://localhost:3000/api/kommo/simulator

OPEN_AI=

OPENAI_MODEL=gpt-4o-mini

KOMMO_SUBDOMAIN=
KOMMO_ACCESS_TOKEN=

# Lucy Admin (panel en /lucy-admin o /admin)
SESSION_SECRET=
# Solo para crear el primer usuario admin (una vez):
# ALLOW_USER_BOOTSTRAP=true

# Opcional: proteger crons /api/kommo/cron/* (header x-cron-secret o ?secret=)
# CRON_SECRET=

# Opcional: ping público adicional desde el propio servidor (complemento, no sustituto del ping externo)
# KEEP_ALIVE_PUBLIC_URL=https://midnightblue-mosquito-424375.hostingersite.com

# ── Catálogo Lucy (Google Sheets + Gamma) ─────────────────────────────────────
# Hoja pública con columnas: servicio | categoría | precio | unidad | notas | tiene_precio
# En Hostinger suele usarse:
# GOOGLE_SHEETS_PRECIOS=<ID del spreadsheet o URL completa del Google Sheet>
# GOOGLE_SHEETS_CATALOG_CSV_URL=https://docs.google.com/spreadsheets/d/ID/export?format=csv&gid=0
# GOOGLE_SHEETS_CATALOG_ID=
# GOOGLE_SHEETS_CATALOG_GID=0
# Pestaña extra con texto libre (opcional):
# GOOGLE_SHEETS_CATALOG_TEXT_GID=
# GOOGLE_SHEETS_CATALOG_TEXT_CSV_URL=
# CATALOG_REFRESH_MINUTES=30

# Gamma — catálogo visual (metadatos + texto publicado)
# GAMMA_API_KEY=
# GAMMA_CATALOG_URL=https://gamma.app/docs/tu-catalogo-xxxxx
# GAMMA_CATALOG_GAMMA_ID=
# GAMMA_CATALOG_TEXT_URL=https://... (texto/markdown publicado para Lucy)
# GAMMA_CATALOG_EXPORT_URL=https://... (PDF estático, opcional)
# GAMMA_ENABLE_EXPORT_API=false
