# Opcional: conecta el simulador a Lucy local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Lucy local (recomendado para el simulador):
AGENT_WEBHOOK_URL=http://localhost:3000/api/kommo/simulator

# Lucy en Hostinger (cuando esté desplegado el endpoint simulator):
# AGENT_WEBHOOK_URL=https://TU-DOMINIO.hostingersite.com/api/kommo/simulator

# Kommo producción (solo cuando conectes el CRM real)
KOMMO_SUBDOMAIN=
KOMMO_ACCESS_TOKEN=

# Base de datos — OPCIONAL (sin esto usa data/lucy-pgdata local)
# DATABASE_URL=postgresql://...

# WhatsApp Meta API
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
